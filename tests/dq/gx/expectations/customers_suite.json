{
  "data_asset_type": null,
  "expectation_suite_name": "customers_suite",
  "expectations": [
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {
        "min_value": 9000,
        "max_value": 11000
      },
      "meta": {"category": "row_count"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "email"},
      "meta": {"category": "not_null"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "name"},
      "meta": {"category": "not_null"}
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "status",
        "value_set": ["active", "inactive", "blocked"]
      },
      "meta": {"category": "referential_integrity"}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "date_of_birth",
        "max_value": "2026-05-11"
      },
      "meta": {"category": "value_range"}
    },
    {
      "expectation_type": "expect_column_values_to_be_unique",
      "kwargs": {"column": "email"},
      "meta": {"category": "uniqueness"}
    },
    {
      "expectation_type": "expect_column_values_to_match_regex",
      "kwargs": {
        "column": "phone",
        "regex": "^\\d{7,15}$"
      },
      "meta": {"category": "format"}
    }
  ],
  "ge_cloud_id": null,
  "meta": {
    "great_expectations_version": "0.18.15"
  }
}
