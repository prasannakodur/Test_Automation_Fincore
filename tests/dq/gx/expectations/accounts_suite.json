{
  "data_asset_type": null,
  "expectation_suite_name": "accounts_suite",
  "expectations": [
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {
        "min_value": 22000,
        "max_value": 28000
      },
      "meta": {"category": "row_count"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "account_number"},
      "meta": {"category": "not_null"}
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "account_type",
        "value_set": ["savings", "current", "fixed_deposit"]
      },
      "meta": {"category": "referential_integrity"}
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "status",
        "value_set": ["active", "dormant", "closed"]
      },
      "meta": {"category": "referential_integrity"}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "balance",
        "min_value": 0
      },
      "meta": {"category": "value_range"}
    },
    {
      "expectation_type": "expect_column_values_to_be_unique",
      "kwargs": {"column": "account_number"},
      "meta": {"category": "uniqueness"}
    }
  ],
  "ge_cloud_id": null,
  "meta": {
    "great_expectations_version": "0.18.15"
