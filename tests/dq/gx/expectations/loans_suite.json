{
  "data_asset_type": null,
  "expectation_suite_name": "loans_suite",
  "expectations": [
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {
        "min_value": 7000,
        "max_value": 9000
      },
      "meta": {"category": "row_count"}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "interest_rate",
        "min_value": 1.0,
        "max_value": 30.0
      },
      "meta": {"category": "value_range"}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "principal_amount",
        "min_value": 0.01
      },
      "meta": {"category": "value_range"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "outstanding_amount"},
      "meta": {"category": "not_null"}
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "status",
        "value_set": ["active", "closed", "defaulted", "restructured"]
      },
      "meta": {"category": "referential_integrity"}
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "loan_type",
        "value_set": ["home", "personal", "auto", "education"]
      },
      "meta": {"category": "referential_integrity"}
    },
    {
      "expectation_type": "expect_column_pair_values_A_to_be_greater_than_B",
      "kwargs": {
        "column_A": "end_date",
        "column_B": "start_date"
      },
      "meta": {"category": "referential_integrity"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "loan_duration_days"},
      "meta": {"category": "computed_fields"}
    }
  ],
  "ge_cloud_id": null,
  "meta": {
    "great_expectations_version": "0.18.15"
  }
